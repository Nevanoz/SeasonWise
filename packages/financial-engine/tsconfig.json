{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declarationDir": "./dist",
    "moduleResolution": "node",
    "module": "CommonJS",
    "rootDir": "../../",
    "paths": {
      "@musimaman/shared-types": ["../shared-types/src/index.ts"],
      "@musimaman/config": ["../config/src/index.ts"]
