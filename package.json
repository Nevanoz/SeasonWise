{
  "name": "musimaman-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npx pnpm --filter @musimaman/web dev",
    "dev:frontend": "npx pnpm --filter @musimaman/web dev",
    "dev:backend": "npx pnpm --filter @musimaman/backend dev",
    "build": "npx pnpm -r build",
    "typecheck": "npx pnpm -r typecheck",
    "lint": "npx pnpm -r lint",
    "test": "npx pnpm -r test",
    "test:e2e": "npx pnpm --filter @musimaman/backend test:integration"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0",
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}

