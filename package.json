{
  "name": "musimaman-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @musimaman/web dev",
    "dev:frontend": "pnpm --filter @musimaman/web dev",
    "dev:backend": "pnpm --filter @musimaman/backend dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @musimaman/backend test:integration"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0",
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}

